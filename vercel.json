{
  "builds": [
    {
      "src": "artifacts/shah-mobile/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "artifacts/shah-mobile/dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/admin(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}